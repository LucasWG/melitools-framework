{
	"compilerOptions": {
		"target": "es2018",
		"module": "esnext",
		"lib": ["dom", "esnext"],
		"strict": true,
		"esModuleInterop": true,
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"rootDir": "./src",
		"outDir": "dist",
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
